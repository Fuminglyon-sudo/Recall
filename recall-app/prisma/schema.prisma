generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deck {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  cards       Card[]
}

model Card {
  id             String      @id @default(cuid())
  deckId         String
  front          String
  back           String
  partOfSpeech   String?
  example        String?
  hook           String?
  synonyms       String?
  association    String?
  kind           String      @default("VOCABULARY")
  sourceContext  String?
  easeFactor     Float       @default(2.5)
  interval       Int         @default(0)
  repetitions    Int         @default(0)
  dueAt          DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deck           Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviewLogs     ReviewLog[]

  @@index([deckId])
  @@index([dueAt])
}

model ReviewLog {
  id         String   @id @default(cuid())
  cardId      String
  grade       Int
  reviewedAt  DateTime @default(now())
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([reviewedAt])
}

model Streak {
  id             String   @id @default(cuid())
  currentStreak  Int      @default(0)
  lastReviewDate DateTime?
}

model VoiceProfile {
  id        String   @id @default(cuid())
  tone      String   @default("")
  updatedAt DateTime @updatedAt
}

model SocialSession {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  scenarioTag       String
  scenarioEmoji     String
  scenarioContext   String
  characterLabel    String
  difficulty        String
  exchangeCount     Int
  score             Int
  strongPoints      Json
  improvements      Json
  powerMove         String
  messages          Json
  modelConversation Json?

  @@index([createdAt])
}

model Country {
  id               String   @id @default(cuid())
  name             String   @unique
  flag             String
  capital          String
  continent        String
  population       String?
  currency         String?
  languages        String
  nationalFood     String?
  phraseLanguage   String?
  phraseHi         String?
  phraseMorning    String?
  phraseAfternoon  String?
  funFact          String?
  interval         Int      @default(1)
  repetitions      Int      @default(0)
  easeFactor       Float    @default(2.5)
  dueAt            DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([dueAt])
  @@index([continent])
}
