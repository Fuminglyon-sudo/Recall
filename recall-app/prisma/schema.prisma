generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth + Prisma adapter) ──────────────────────────────────────
// These four models are required by @auth/prisma-adapter.
// The Session model is defined here but not actively used — we run JWT sessions
// so tokens live in cookies, not the database.

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  accounts          Account[]
  sessions          Session[]
  decks             Deck[]
  streak            Streak?
  voiceProfile      VoiceProfile?
  socialSessions    SocialSession[]
  speakUpSessions   SpeakUpSession[]
  countryProgress   UserCountryProgress[]

  @@index([email])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Core app ──────────────────────────────────────────────────────────────

model Deck {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  // null = admin-owned (pre-existing data); set for all new user decks
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards       Card[]

  @@index([userId])
}

model Card {
  id             String      @id @default(cuid())
  deckId         String
  front          String
  back           String
  partOfSpeech   String?
  example        String?
  hook           String?
  synonyms       String?
  association    String?
  kind           String      @default("VOCABULARY")
  sourceContext  String?
  easeFactor     Float       @default(2.5)
  interval       Int         @default(0)
  repetitions    Int         @default(0)
  dueAt          DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deck           Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviewLogs     ReviewLog[]

  @@index([deckId])
  @@index([dueAt])
}

model ReviewLog {
  id         String   @id @default(cuid())
  cardId     String
  grade      Int
  reviewedAt DateTime @default(now())
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([reviewedAt])
}

model Streak {
  id             String    @id @default(cuid())
  currentStreak  Int       @default(0)
  lastReviewDate DateTime?
  // null = admin streak; set for all new users
  userId         String?   @unique
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VoiceProfile {
  id        String   @id @default(cuid())
  tone      String   @default("")
  updatedAt DateTime @updatedAt
  // null = admin profile; set for all new users
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SocialSession {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  scenarioTag       String
  scenarioEmoji     String
  scenarioContext   String
  characterLabel    String
  difficulty        String
  exchangeCount     Int
  score             Int
  strongPoints      Json
  improvements      Json
  powerMove         String
  messages          Json
  modelConversation Json?
  practiceGoal      String?
  // null = admin session; set for all new users
  userId            String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

model SpeakUpSession {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  scenarioId   String
  scenarioTag  String
  personaId    String
  personaLabel String
  difficulty   String
  practiceGoal String?
  exchangeCount Int
  score        Int
  strongPoints Json
  improvements Json
  modelAnswer  String
  messages     Json
  // null = admin session; set for all new users
  userId       String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ─── Push Notifications ────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  // null = admin; cuid = Google user
  userId    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Countries ─────────────────────────────────────────────────────────────
// Country reference data is shared. Per-user spaced-repetition progress
// lives in UserCountryProgress.

model Country {
  id              String   @id @default(cuid())
  name            String   @unique
  flag            String
  capital         String
  continent       String
  population      String?
  currency        String?
  languages       String
  nationalFood    String?
  phraseLanguage  String?
  phraseHi        String?
  phraseMorning   String?
  phraseAfternoon String?
  funFact         String?
  // Legacy SM-2 fields kept for admin (null userId path); new users use UserCountryProgress
  interval        Int      @default(1)
  repetitions     Int      @default(0)
  easeFactor      Float    @default(2.5)
  dueAt           DateTime @default(now())
  createdAt       DateTime @default(now())

  userProgress UserCountryProgress[]

  @@index([dueAt])
  @@index([continent])
}

model UserCountryProgress {
  id          String   @id @default(cuid())
  userId      String
  countryId   String
  interval    Int      @default(1)
  repetitions Int      @default(0)
  easeFactor  Float    @default(2.5)
  dueAt       DateTime @default(now())
  createdAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([userId, countryId])
  @@index([userId, dueAt])
}
